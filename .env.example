# ─────────────────────────────────────────────────────────────────────
# Rushit Shah Portfolio — environment variables
#
# Copy this file to .env.local for local development, and paste the
# same keys into Vercel → Project → Settings → Environment Variables
# for production. Values below are placeholders; real secrets go in
# .env.local (which is gitignored) and in Vercel.
# ─────────────────────────────────────────────────────────────────────

# ── Payload ──────────────────────────────────────────────────────────
# 64-char hex. Generate with:  openssl rand -hex 32
PAYLOAD_SECRET=replace-with-64-char-hex

# Neon Postgres connection string. Looks like:
#   postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URI=postgres://user:password@host/db?sslmode=require


# ── Cloudflare R2 (S3-compatible media storage) ──────────────────────
# Create an R2 bucket + API token in the Cloudflare dashboard, then paste:
S3_BUCKET=rushit-shah-media
S3_ACCESS_KEY_ID=replace-with-r2-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto


# ── Contact form (Web3Forms) ─────────────────────────────────────────
# Public key — it's embedded in the client-side form anyway. Having it
# as an env var just makes rotation painless.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=1e756e4d-a754-49d7-a5e4-dcfd18fe6855


# ── Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.rushitshah.com


# ─────────────────────────────────────────────────────────────────────
# Notes:
#   • Gallery on /collection uses ArtworkArchive's public embed script;
#     no API key required.
#   • If you want to use SMTP for receipt emails to the collector, wire
#     EMAIL_* vars back in here and read them from a server route.
# ─────────────────────────────────────────────────────────────────────
